{
  "activePattern": "pathSegmentIndex",
  "patterns": {
    "pathSegmentPattern": {
      "regex": ".*_.*",
      "searchTarget": "directoriesOnly",
      "fallback": "firstDirectory"
    },
    "pathSegmentIndex": {
      "index": 1,
      "fallback": "firstDirectory"
    },
    "parentDirectory": {
      "levelsUpFromFile": 2,
      "fallback": "firstDirectory"
    }
  }
}
